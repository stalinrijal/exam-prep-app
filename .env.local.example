# Supabase — get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Only used server-side (API routes, server components) — never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin email(s) — comma separated. Users with these emails get admin access.
NEXT_PUBLIC_ADMIN_EMAILS=admin@yourdomain.com

# Your app URL (for auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
